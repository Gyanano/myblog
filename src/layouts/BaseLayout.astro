---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import { SITE } from "../consts";
import InkCanvas from "../components/InkCanvas.astro";
import Cursor from "../components/Cursor.astro";
import Nav from "../components/Nav.astro";
import Watermark from "../components/Watermark.astro";
import ScrollLandscape from "../components/ScrollLandscape.astro";
import Footer from "../components/Footer.astro";
import TransitionOverlay from "../components/TransitionOverlay.astro";
import BackToTop from "../components/BackToTop.astro";

interface Props {
  title?: string;
  description?: string;
}
const { title, description = SITE.description } = Astro.props;
const fullTitle = title ? `${title} · ${SITE.author}` : SITE.title;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@300;400&family=Noto+Serif+SC:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <script is:inline>
      // 无闪烁应用昼夜主题（在首帧前）
      (function () {
        try {
          if (localStorage.getItem("theme") === "dark")
            document.documentElement.setAttribute("data-theme", "dark");
        } catch (e) {}
      })();
    </script>
    <script is:inline>
      // 绕过浏览器原生 View Transitions 的整页快照：过场由我们自己的水墨遮罩完成，
      // 不需要浏览器为一个用不到的视觉过渡拍新旧两张快照（换页卡顿的真凶，codex 经
      // 读 Astro 运行时源码确认）。必须在 <ClientRouter /> 加载前替换，
      // 这样 Astro 探测 supportsViewTransitions 时拿到的就是这个直通实现。
      // 注：主题切换从不调用 navigate()/startViewTransition，故此改动不影响主题切换。
      (function () {
        if (!document.startViewTransition) return;
        document.startViewTransition = function (updateCallback) {
          var updateCallbackDone = Promise.resolve().then(updateCallback);
          var finished = updateCallbackDone.then(function () {
            return new Promise(function (resolve) {
              requestAnimationFrame(function () {
                requestAnimationFrame(resolve);
              });
            });
          });
          return {
            updateCallbackDone: updateCallbackDone,
            ready: updateCallbackDone,
            finished: finished,
            skipTransition: function () {},
            types: new Set(),
          };
        };
      })();
    </script>
    <ClientRouter />
  </head>
  <body>
    <InkCanvas />
    <Cursor />
    <Watermark />
    <ScrollLandscape />
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
    <TransitionOverlay />
    <BackToTop />

    <!-- 全局 GSAP 入场动画（跨页重新初始化，过渡前清理 ScrollTrigger） -->
    <script>
      import gsap from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";
      import Lenis from "lenis";
      gsap.registerPlugin(ScrollTrigger);

      // 平滑滚动（阻尼）。画卷直接跟随平滑后的 scrollY，二者共用同一缓动 → 同步一致。
      let lenis: any = null;
      function initLenis() {
        if (lenis) return;
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        lenis = new Lenis({ lerp: 0.09, smoothWheel: true });
        lenis.on("scroll", ScrollTrigger.update);
        gsap.ticker.add((time: number) => lenis.raf(time * 1000));
        gsap.ticker.lagSmoothing(0);
        (window as any).__lenis = lenis;
      }

      // 完全在视口下方（揭幕时根本不可见）才允许滚动入场
      function belowFold(el: HTMLElement) {
        return el.getBoundingClientRect().top >= window.innerHeight;
      }

      // 构建入场动画。
      // settleInView=true（过场导航：蒙版正盖住屏幕）：先把所有目标无条件定为终态，
      // 保证揭幕时可见区域 100% 静止；只给完全在视口下方的元素重新绑定滚动入场。
      // settleInView=false（首次加载 / 前进后退，无蒙版）：照常播放全部入场动画。
      function buildReveal(settleInView: boolean) {
        const titles = gsap.utils.toArray<HTMLElement>(".gs-title");
        const fades = gsap.utils.toArray<HTMLElement>(".gs-fade-up");
        const groups = gsap.utils.toArray<HTMLElement>(".gs-stagger");

        if (!settleInView) {
          titles.forEach((t) =>
            gsap.from(t, {
              opacity: 0,
              y: 40,
              duration: 0.9,
              ease: "power3.out",
              scrollTrigger: { trigger: t, start: "top 85%" },
            }),
          );
          fades.forEach((t) =>
            gsap.from(t, { opacity: 0, y: 50, duration: 1.0, ease: "power3.out" }),
          );
          groups.forEach((g) => {
            if (g.children.length)
              gsap.from(g.children, {
                opacity: 0,
                y: 30,
                duration: 0.8,
                stagger: 0.1,
                ease: "power2.out",
                scrollTrigger: { trigger: g, start: "top 82%" },
              });
          });
          ScrollTrigger.refresh();
          return;
        }

        // 过场：盖住期间只把内容定为终态，绝不碰布局（不建 ScrollTrigger、不 refresh）。
        if (titles.length) gsap.set(titles, { opacity: 1, y: 0 });
        if (fades.length) gsap.set(fades, { opacity: 1, y: 0 });
        groups.forEach((g) => {
          if (g.children.length) gsap.set(g.children, { opacity: 1, y: 0 });
        });
        // 把"视口下方元素的滚动入场绑定 + lenis.resize + ScrollTrigger.refresh"全部推迟到
        // 揭幕动画结束后的空闲时段，避免同步重排/刷新落在揭幕首帧上（揭幕卡顿真凶）。
        (window as any).__afterInkReveal = () => {
          const run = () => {
            if (lenis) lenis.resize();
            titles.forEach((t) => {
              if (belowFold(t))
                gsap.from(t, {
                  opacity: 0,
                  y: 40,
                  duration: 0.9,
                  ease: "power3.out",
                  scrollTrigger: { trigger: t, start: "top 85%" },
                });
            });
            groups.forEach((g) => {
              if (g.children.length && belowFold(g))
                gsap.from(g.children, {
                  opacity: 0,
                  y: 30,
                  duration: 0.8,
                  stagger: 0.1,
                  ease: "power2.out",
                  scrollTrigger: { trigger: g, start: "top 82%" },
                });
            });
            ScrollTrigger.refresh();
            delete (window as any).__afterInkReveal;
          };
          if ("requestIdleCallback" in window) {
            (window as any).requestIdleCallback(run, { timeout: 800 });
          } else {
            window.setTimeout(run, 180);
          }
        };
      }

      function cleanupReveal() {
        ScrollTrigger.getAll().forEach((t) => t.kill());
      }

      function onPageLoad() {
        initLenis();
        const isNav = !!(window as any).__inkNav;
        if (lenis) {
          lenis.scrollTo(0, { immediate: true });
          if (!isNav) lenis.resize(); // 过场时 resize 推迟到揭幕后（见 __afterInkReveal）
        }
        // __inkNav 为真表示这是一次过场导航（蒙版正盖住），把工作做在蒙版下
        buildReveal(isNav);
      }

      document.addEventListener("astro:page-load", onPageLoad);
      document.addEventListener("astro:before-swap", cleanupReveal);
    </script>
  </body>
</html>
