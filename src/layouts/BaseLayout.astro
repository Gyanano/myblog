---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import { SITE } from "../consts";
import InkCanvas from "../components/InkCanvas.astro";
import Cursor from "../components/Cursor.astro";
import Nav from "../components/Nav.astro";
import Watermark from "../components/Watermark.astro";
import ScrollLandscape from "../components/ScrollLandscape.astro";
import Footer from "../components/Footer.astro";
import TransitionOverlay from "../components/TransitionOverlay.astro";

interface Props {
  title?: string;
  description?: string;
}
const { title, description = SITE.description } = Astro.props;
const fullTitle = title ? `${title} · ${SITE.author}` : SITE.title;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@300;400&family=Noto+Serif+SC:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <script is:inline>
      // 无闪烁应用昼夜主题（在首帧前）
      (function () {
        try {
          if (localStorage.getItem("theme") === "dark")
            document.documentElement.setAttribute("data-theme", "dark");
        } catch (e) {}
      })();
    </script>
    <ClientRouter />
  </head>
  <body>
    <InkCanvas />
    <Cursor />
    <Watermark />
    <ScrollLandscape />
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
    <TransitionOverlay />

    <!-- 全局 GSAP 入场动画（跨页重新初始化，过渡前清理 ScrollTrigger） -->
    <script>
      import gsap from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";
      import Lenis from "lenis";
      gsap.registerPlugin(ScrollTrigger);

      // 平滑滚动（阻尼）。画卷直接跟随平滑后的 scrollY，二者共用同一缓动 → 同步一致。
      let lenis: any = null;
      function initLenis() {
        if (lenis) return;
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        lenis = new Lenis({ lerp: 0.09, smoothWheel: true });
        lenis.on("scroll", ScrollTrigger.update);
        gsap.ticker.add((time: number) => lenis.raf(time * 1000));
        gsap.ticker.lagSmoothing(0);
        (window as any).__lenis = lenis;
      }

      function isInView(el: HTMLElement) {
        const r = el.getBoundingClientRect();
        return r.top < window.innerHeight * 0.9 && r.bottom > 0;
      }

      // 构建入场动画。
      // settleInView=true（过场导航：此刻蒙版正盖住屏幕）：已在视口内的元素直接定为
      // 终态、不做动画——加载/布局/重排的卡顿都藏在蒙版下，揭幕后即是稳定页面；
      // 视口外的元素仍保留随滚动淡入。
      // settleInView=false（首次加载 / 前进后退，无蒙版）：照常播放入场动画。
      function buildReveal(settleInView: boolean) {
        function handle(el: HTMLElement, from: Record<string, number>, dur: number, ease: string) {
          if (settleInView && isInView(el)) {
            gsap.set(el, { opacity: 1, y: 0 });
          } else {
            gsap.from(el, {
              ...from,
              duration: dur,
              ease,
              scrollTrigger: { trigger: el, start: "top 85%" },
            });
          }
        }
        gsap.utils
          .toArray<HTMLElement>(".gs-title")
          .forEach((t) => handle(t, { opacity: 0, y: 40 }, 0.9, "power3.out"));
        gsap.utils
          .toArray<HTMLElement>(".gs-fade-up")
          .forEach((t) => handle(t, { opacity: 0, y: 50 }, 1.0, "power3.out"));
        gsap.utils.toArray<HTMLElement>(".gs-stagger").forEach((g) => {
          const items = g.children;
          if (!items.length) return;
          if (settleInView && isInView(g)) {
            gsap.set(items, { opacity: 1, y: 0 });
          } else {
            gsap.from(items, {
              opacity: 0,
              y: 30,
              duration: 0.8,
              stagger: 0.1,
              ease: "power2.out",
              scrollTrigger: { trigger: g, start: "top 82%" },
            });
          }
        });
        ScrollTrigger.refresh();
      }

      function cleanupReveal() {
        ScrollTrigger.getAll().forEach((t) => t.kill());
      }

      function onPageLoad() {
        initLenis();
        if (lenis) {
          lenis.scrollTo(0, { immediate: true });
          lenis.resize();
        }
        // __inkNav 为真表示这是一次过场导航（蒙版正盖住），把工作做在蒙版下
        buildReveal(!!(window as any).__inkNav);
      }

      document.addEventListener("astro:page-load", onPageLoad);
      document.addEventListener("astro:before-swap", cleanupReveal);
    </script>
  </body>
</html>
