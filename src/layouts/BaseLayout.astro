---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import { SITE } from "../consts";
import InkCanvas from "../components/InkCanvas.astro";
import Cursor from "../components/Cursor.astro";
import Nav from "../components/Nav.astro";
import Watermark from "../components/Watermark.astro";
import ScrollLandscape from "../components/ScrollLandscape.astro";
import Footer from "../components/Footer.astro";
import TransitionOverlay from "../components/TransitionOverlay.astro";

interface Props {
  title?: string;
  description?: string;
}
const { title, description = SITE.description } = Astro.props;
const fullTitle = title ? `${title} · ${SITE.author}` : SITE.title;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@300;400&family=Noto+Serif+SC:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <script is:inline>
      // 无闪烁应用昼夜主题（在首帧前）
      (function () {
        try {
          if (localStorage.getItem("theme") === "dark")
            document.documentElement.setAttribute("data-theme", "dark");
        } catch (e) {}
      })();
    </script>
    <ClientRouter />
  </head>
  <body>
    <InkCanvas />
    <Cursor />
    <Watermark />
    <ScrollLandscape />
    <Nav />
    <main transition:animate="fade">
      <slot />
    </main>
    <Footer />
    <TransitionOverlay />

    <!-- 全局 GSAP 入场动画（跨页重新初始化，过渡前清理 ScrollTrigger） -->
    <script>
      import gsap from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";
      import Lenis from "lenis";
      gsap.registerPlugin(ScrollTrigger);

      // 平滑滚动（阻尼）。画卷直接跟随平滑后的 scrollY，二者共用同一缓动 → 同步一致。
      let lenis: any = null;
      function initLenis() {
        if (lenis) return;
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        lenis = new Lenis({ lerp: 0.09, smoothWheel: true });
        lenis.on("scroll", ScrollTrigger.update);
        gsap.ticker.add((time: number) => lenis.raf(time * 1000));
        gsap.ticker.lagSmoothing(0);
        (window as any).__lenis = lenis;
      }

      function runReveal() {
        // 标题入场
        gsap.utils.toArray<HTMLElement>(".gs-title").forEach((title) => {
          gsap.from(title, {
            scrollTrigger: { trigger: title, start: "top 85%" },
            y: 40,
            opacity: 0,
            duration: 1.2,
            ease: "power3.out",
          });
        });
        // 错落入场
        gsap.utils.toArray<HTMLElement>(".gs-stagger").forEach((group) => {
          const items = group.children;
          if (items.length) {
            gsap.from(items, {
              scrollTrigger: { trigger: group, start: "top 80%" },
              y: 30,
              opacity: 0,
              duration: 1,
              stagger: 0.15,
              ease: "power2.out",
            });
          }
        });
        // 首屏淡入元素
        gsap.utils.toArray<HTMLElement>(".gs-fade-up").forEach((el) => {
          gsap.from(el, { y: 50, opacity: 0, duration: 1.5, delay: 0.3, ease: "power3.out" });
        });
        ScrollTrigger.refresh();
      }

      function cleanupReveal() {
        ScrollTrigger.getAll().forEach((t) => t.kill());
      }

      function onPageLoad() {
        initLenis();
        if (lenis) {
          lenis.scrollTo(0, { immediate: true });
          lenis.resize();
        }
        runReveal();
      }

      document.addEventListener("astro:page-load", onPageLoad);
      document.addEventListener("astro:before-swap", cleanupReveal);
    </script>
  </body>
</html>
