---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import { SITE } from "../consts";
import InkCanvas from "../components/InkCanvas.astro";
import Cursor from "../components/Cursor.astro";
import Nav from "../components/Nav.astro";
import Watermark from "../components/Watermark.astro";
import ScrollLandscape from "../components/ScrollLandscape.astro";
import Footer from "../components/Footer.astro";
import TransitionOverlay from "../components/TransitionOverlay.astro";

interface Props {
  title?: string;
  description?: string;
}
const { title, description = SITE.description } = Astro.props;
const fullTitle = title ? `${title} · ${SITE.author}` : SITE.title;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@300;400&family=Noto+Serif+SC:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <script is:inline>
      // 无闪烁应用昼夜主题（在首帧前）
      (function () {
        try {
          if (localStorage.getItem("theme") === "dark")
            document.documentElement.setAttribute("data-theme", "dark");
        } catch (e) {}
      })();
    </script>
    <ClientRouter />
  </head>
  <body>
    <InkCanvas />
    <Cursor />
    <Watermark />
    <ScrollLandscape />
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
    <TransitionOverlay />

    <!-- 全局 GSAP 入场动画（跨页重新初始化，过渡前清理 ScrollTrigger） -->
    <script>
      import gsap from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";
      import Lenis from "lenis";
      gsap.registerPlugin(ScrollTrigger);

      // 平滑滚动（阻尼）。画卷直接跟随平滑后的 scrollY，二者共用同一缓动 → 同步一致。
      let lenis: any = null;
      function initLenis() {
        if (lenis) return;
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        lenis = new Lenis({ lerp: 0.09, smoothWheel: true });
        lenis.on("scroll", ScrollTrigger.update);
        gsap.ticker.add((time: number) => lenis.raf(time * 1000));
        gsap.ticker.lagSmoothing(0);
        (window as any).__lenis = lenis;
      }

      // 先把入场目标置为隐藏初态（藏在遮罩下，避免揭幕瞬间闪现）
      function hideRevealTargets() {
        const titles = gsap.utils.toArray<HTMLElement>(".gs-title");
        if (titles.length) gsap.set(titles, { opacity: 0, y: 40 });
        const fades = gsap.utils.toArray<HTMLElement>(".gs-fade-up");
        if (fades.length) gsap.set(fades, { opacity: 0, y: 50 });
        gsap.utils.toArray<HTMLElement>(".gs-stagger").forEach((g) => {
          if (g.children.length) gsap.set(g.children, { opacity: 0, y: 30 });
        });
      }

      // 真正播放入场（从隐藏初态淡入）。在揭幕动画跑完后再调用，二者不再抢帧。
      function playReveal() {
        gsap.utils.toArray<HTMLElement>(".gs-title").forEach((title) => {
          gsap.to(title, {
            scrollTrigger: { trigger: title, start: "top 85%" },
            y: 0,
            opacity: 1,
            duration: 0.9,
            ease: "power3.out",
          });
        });
        gsap.utils.toArray<HTMLElement>(".gs-stagger").forEach((group) => {
          const items = group.children;
          if (items.length) {
            gsap.to(items, {
              scrollTrigger: { trigger: group, start: "top 82%" },
              y: 0,
              opacity: 1,
              duration: 0.8,
              stagger: 0.1,
              ease: "power2.out",
            });
          }
        });
        gsap.utils.toArray<HTMLElement>(".gs-fade-up").forEach((el) => {
          gsap.to(el, { y: 0, opacity: 1, duration: 1.0, delay: 0.05, ease: "power3.out" });
        });
        ScrollTrigger.refresh();
      }
      (window as any).__playReveal = playReveal;

      function cleanupReveal() {
        ScrollTrigger.getAll().forEach((t) => t.kill());
      }

      function onPageLoad() {
        initLenis();
        if (lenis) {
          lenis.scrollTo(0, { immediate: true });
          lenis.resize();
        }
        hideRevealTargets();
        // 过场导航时，由 TransitionOverlay 在揭幕后再调用 __playReveal；
        // 首次加载 / 前进后退则立即播放。
        if (!(window as any).__inkNav) playReveal();
      }

      document.addEventListener("astro:page-load", onPageLoad);
      document.addEventListener("astro:before-swap", cleanupReveal);
    </script>
  </body>
</html>
