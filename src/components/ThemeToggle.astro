---
// 昼夜（宣纸/墨夜）切换印章。复用水墨蒙版：盖墨 → 在蒙版下做颜色渐变 →
// 渐变完成后蒙版上滑露出新配色。颜色 morph 的卡顿全藏在蒙版之下。
---

<button id="theme-toggle" class="seal-btn" type="button" aria-label="切换昼夜" title="昼夜" data-cursor>
  <span class="seal-night">夜</span><span class="seal-day">昼</span>
</button>

<script>
  const COVER_MS = 280;
  const HOLD_MS = 380; // 蒙版下颜色渐变时长（略大于 CSS 过渡 0.35s）
  const REVEAL_MS = 340;
  const EASE = "cubic-bezier(.6,0,.2,1)";

  function applyTheme(t: string) {
    document.documentElement.setAttribute("data-theme", t);
    try {
      localStorage.setItem("theme", t);
    } catch {}
  }

  function overlay() {
    return document.getElementById("ink-transition");
  }
  function animT(from: string, to: string, dur: number) {
    const t = overlay();
    if (!t) return Promise.resolve();
    // 清掉遗留动画，杜绝 fill:forwards 累积并覆盖 inline 复位（多次切换后揭幕瞬跳的真凶）
    t.getAnimations().forEach((a) => a.cancel());
    t.style.transform = `translateY(${from})`;
    const anim = t.animate(
      [{ transform: `translateY(${from})` }, { transform: `translateY(${to})` }],
      { duration: dur, easing: EASE, fill: "forwards" },
    );
    return anim.finished
      .then(() => {
        // 把终态写进 inline，再撤掉动画——不留 fill，inline 复位才真正生效
        try {
          anim.commitStyles();
        } catch {}
        anim.cancel();
      })
      .catch(() => {});
  }
  function wait(ms: number) {
    return new Promise((r) => window.setTimeout(r, ms));
  }

  let busy = false;

  function initThemeToggle() {
    const btn = document.getElementById("theme-toggle");
    if (!btn || btn.dataset.bound === "1") return;
    btn.dataset.bound = "1";
    btn.addEventListener("click", async (e) => {
      e.stopPropagation();
      if (busy) return;
      busy = true;
      const root = document.documentElement;
      const cur = root.getAttribute("data-theme") === "dark" ? "dark" : "light";
      const next = cur === "dark" ? "light" : "dark";
      (window as any).__inkPause?.(); // 过渡期间暂停墨场
      document.documentElement.classList.add("ink-transitioning"); // 关闭全屏混合
      const t = overlay();
      if (t) t.style.transform = "translateY(100%)";
      await animT("100%", "0%", COVER_MS); // 盖墨
      root.classList.add("theme-anim"); // 颜色过渡开启
      applyTheme(next); // 在蒙版下渐变
      await wait(HOLD_MS); // 等颜色渐变完成
      // 渐变已完成：先撤掉通配过渡（揭幕期间不再让每个元素都跟踪 transition），
      // 再用双 rAF 等本帧绘制落定——与页面切换揭幕同一套时序，避免揭幕首帧被
      // 色彩重绘抢占导致“追帧瞬跳”，让揭幕全程只剩合成层位移。
      root.classList.remove("theme-anim");
      await new Promise<void>((r) =>
        requestAnimationFrame(() => requestAnimationFrame(() => r())),
      );
      await animT("0%", "-100%", REVEAL_MS); // 揭幕露出新配色
      if (t) t.style.transform = "translateY(100%)";
      root.classList.remove("ink-transitioning"); // 恢复墨韵混合
      (window as any).__inkResume?.();
      busy = false;
    });
  }
  document.addEventListener("astro:page-load", initThemeToggle);
</script>
