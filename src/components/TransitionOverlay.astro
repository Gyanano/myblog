---
// 水墨过场遮罩。自己接管内部链接导航时序：
// 点击 → 墨盖满屏幕 → navigate() 在遮罩底下完成切换 → 落地后揭墨。
// 这样「盖墨」一定先于「切换」，两段动画不再打架；GSAP 重建也藏在遮罩下。
// 仅用 transform: translateY（合成层），开销低。
---

<div id="ink-transition" aria-hidden="true" transition:persist="ink-transition">
  <div class="ink-loader" aria-hidden="true">
    <span class="ink-loader-dot"></span>
    <span class="ink-loader-text">墨迹未干…</span>
  </div>
</div>

<script>
  import { navigate } from "astro:transitions/client";

  const COVER_MS = 300;
  const REVEAL_MS = 340;
  const SETTLE_MS = 120; // 双 rAF 预绘制后再稳定一小段，然后揭幕
  const EASE = "cubic-bezier(.6,0,.2,1)";

  const LOADER_DELAY = 350; // 盖满后超过该时长仍未落地，才显示“加载中”（快速跳转不闪现）

  let busy = false; // 正在过场
  let pendingReveal = false; // 落地后需要揭墨
  let loaderTimer: number | undefined; // 延迟显示加载指示的计时器

  function el() {
    return document.getElementById("ink-transition");
  }

  function animTo(from: string, to: string, dur: number) {
    const t = el();
    if (!t) return Promise.resolve();
    // 清掉遗留动画，杜绝 fill:forwards 累积并覆盖 inline 复位
    t.getAnimations().forEach((a) => a.cancel());
    t.style.transform = `translateY(${from})`;
    const anim = t.animate(
      [{ transform: `translateY(${from})` }, { transform: `translateY(${to})` }],
      { duration: dur, easing: EASE, fill: "forwards" },
    );
    return anim.finished
      .then(() => {
        try {
          anim.commitStyles();
        } catch {}
        anim.cancel();
      })
      .catch(() => {});
  }

  function isInternalNav(a: HTMLAnchorElement): string | null {
    const href = a.getAttribute("href");
    if (!href) return null;
    if (a.target === "_blank" || a.hasAttribute("download")) return null;
    if (a.dataset.noTransition !== undefined) return null;
    let url: URL;
    try {
      url = new URL(a.href, location.href);
    } catch {
      return null;
    }
    if (url.origin !== location.origin) return null; // 外链 / mailto 等
    if (url.pathname === location.pathname && url.search === location.search) return null; // 同页/锚点
    return url.href;
  }

  // 捕获阶段拦截，先于 ClientRouter 的点击处理
  document.addEventListener(
    "click",
    (e) => {
      if (e.defaultPrevented) return;
      if (e.button !== 0 || e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
      const target = e.target as HTMLElement;
      const a = target.closest("a") as HTMLAnchorElement | null;
      if (!a) return;
      const dest = isInternalNav(a);
      if (!dest) return;
      e.preventDefault();
      e.stopPropagation();
      if (busy) return;
      busy = true;
      (window as any).__inkNav = true; // 通知 BaseLayout：入场动画等揭幕后再播
      (window as any).__inkPause?.(); // 过渡期间暂停墨场，腾出资源
      document.documentElement.classList.add("ink-transitioning"); // 关闭全屏混合 + 提升内容层
      const t = el();
      if (t) t.style.transform = "translateY(100%)";
      animTo("100%", "0%", COVER_MS).then(() => {
        pendingReveal = true;
        // 慢加载才显示“加载中”；落地（astro:page-load）会清掉这个计时器
        loaderTimer = window.setTimeout(() => t?.classList.add("is-loading"), LOADER_DELAY);
        navigate(dest);
      });
    },
    { capture: true },
  );

  document.addEventListener("astro:page-load", () => {
    busy = false;
    window.clearTimeout(loaderTimer); // 已落地，取消待显示的加载指示
    const t = el();
    if (!t) return;
    t.classList.remove("is-loading"); // 揭幕前先隐藏加载指示，绝不与上滑动画并存
    if (!pendingReveal) {
      // 首次加载 / 前进后退：不揭墨，保持停在屏外
      t.style.transform = "translateY(100%)";
      return;
    }
    pendingReveal = false;
    // 关键：ClientRouter 的 swap 会清空 <html> 的 class，盖墨时加的 ink-transitioning
    // 在换页后丢失，导致揭幕滑动期间「关混合层 + 提升 main 图层」的优化全部失效，
    // InkCanvas/山水图的 mix-blend 每帧回读重绘 → 揭幕闪屏。换页后重新挂上，揭幕结束再移除。
    document.documentElement.classList.add("ink-transitioning");
    // 双 rAF 先逼浏览器把新页面绘制出一帧（含布局/栅格化），再短暂稳定，最后揭幕。
    // 这样新内容的首帧绘制不会与揭幕动画撞在一起，揭幕全程只剩合成层位移。
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        window.setTimeout(() => {
          animTo("0%", "-100%", REVEAL_MS).then(() => {
            if (t) t.style.transform = "translateY(100%)";
            (window as any).__inkNav = false;
            document.documentElement.classList.remove("ink-transitioning"); // 恢复墨韵混合
            (window as any).__inkResume?.();
            // 揭幕已结束：此刻才做 ScrollTrigger 绑定/refresh/lenis.resize（空闲时段）
            (window as any).__afterInkReveal?.();
          });
        }, SETTLE_MS);
      });
    });
  });
</script>
