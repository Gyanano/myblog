---
interface Props {
  current: number;
  total: number;
}
const { current, total } = Astro.props;
const href = (p: number) => (p === 1 ? "/blog" : `/blog/page/${p}`);
const pages = Array.from({ length: total }, (_, i) => i + 1);
---

{total > 1 && (
  <nav class="pager" aria-label="分页">
    {current > 1 ? (
      <a class="pager-link" href={href(current - 1)} data-cursor>← 上一页</a>
    ) : (
      <span class="pager-link is-disabled">← 上一页</span>
    )}
    <div class="pager-nums">
      {pages.map((p) =>
        p === current ? (
          <span class="pager-num is-active">{p}</span>
        ) : (
          <a class="pager-num" href={href(p)} data-cursor>{p}</a>
        ),
      )}
    </div>
    {current < total ? (
      <a class="pager-link" href={href(current + 1)} data-cursor>下一页 →</a>
    ) : (
      <span class="pager-link is-disabled">下一页 →</span>
    )}
  </nav>
)}
