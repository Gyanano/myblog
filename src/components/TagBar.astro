---
import { groupTags, type Post } from "../lib/blog";
interface Props {
  posts: Post[]; // 传全部已发布文章，保证各页标签栏一致
  active?: string;
}
const { posts, active } = Astro.props;
const groups = groupTags(posts); // 按「技术 / 玄学」分组
---

<nav class="tag-bar" aria-label="文章分类">
  <a class:list={["tag-chip", "tag-all", { "is-active": !active }]} href="/blog" data-cursor>
    全部 <span class="tag-count">{posts.length}</span>
  </a>
  {groups.map((g) => (
    <div class="tag-group">
      <span class="tag-group-label">{g.label}</span>
      <div class="tag-group-chips">
        {g.items.map(({ tag, count }) => (
          <a
            class:list={["tag-chip", { "is-active": active === tag }]}
            href={`/blog/tags/${encodeURIComponent(tag)}`}
            data-cursor
          >
            #{tag} <span class="tag-count">{count}</span>
          </a>
        ))}
      </div>
    </div>
  ))}
</nav>
