---
// 底部水墨山水长卷（《富春山居图》局部）。随页面滚动横向平移，
// 如展开长卷从左看到右；山体整体向左移动，营造置身画中的卷轴感。跨页保留。
---

<div class="scroll-painting-container" aria-hidden="true" transition:persist="landscape">
  <img class="scroll-painting" id="scroll-painting" src="/fuchun.jpg" alt="" />
</div>

<script>
  function initLandscape() {
    if ((window as any).__landscapeBound) return;
    (window as any).__landscapeBound = true;
    const painting = document.getElementById("scroll-painting") as HTMLImageElement | null;
    if (!painting) return;

    let ticking = false;
    const update = () => {
      const scrollY = window.scrollY;
      const scrollHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = scrollHeight > 0 ? Math.min(1, Math.max(0, scrollY / scrollHeight)) : 0;
      // 整幅长卷从左端平移到右端：山体随滚动向左移动
      const maxX = painting.scrollWidth - window.innerWidth;
      const x = -progress * Math.max(0, maxX);
      painting.style.transform = `translateX(${x}px)`;
      ticking = false;
    };

    window.addEventListener(
      "scroll",
      () => {
        if (ticking) return;
        ticking = true;
        window.requestAnimationFrame(update);
      },
      { passive: true },
    );
    window.addEventListener("resize", update);
    // 图片尺寸就绪后再算一次
    if (painting.complete) update();
    else painting.addEventListener("load", update, { once: true });
    update();
  }
  document.addEventListener("astro:page-load", initLandscape);
</script>
