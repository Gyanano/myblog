---
// 底部水墨山水长卷（《富春山居图》局部）。随页面滚动横向平移，
// 用 rAF 阻尼跟随（缓动），让山体平移带有惯性/阻尼感，不生硬。跨页保留。
---

<div class="scroll-painting-container" aria-hidden="true" transition:persist="landscape">
  <img class="scroll-painting" id="scroll-painting" src="/fuchun.jpg" alt="" />
</div>

<script>
  function initLandscape() {
    if ((window as any).__landscapeBound) return;
    (window as any).__landscapeBound = true;
    const painting = document.getElementById("scroll-painting") as HTMLImageElement | null;
    if (!painting) return;

    let target = 0;
    let current = 0;
    let running = false;
    let raf = 0;

    const computeTarget = () => {
      const h = document.documentElement.scrollHeight - window.innerHeight;
      const p = h > 0 ? Math.min(1, Math.max(0, window.scrollY / h)) : 0;
      const maxX = Math.max(0, painting.scrollWidth - window.innerWidth);
      target = -p * maxX;
    };

    const tick = () => {
      // 阻尼缓动：每帧朝目标靠近一定比例，产生惯性拖尾
      current += (target - current) * 0.085;
      if (Math.abs(target - current) < 0.4) {
        current = target;
        running = false;
      }
      painting.style.transform = `translate3d(${current}px,0,0)`;
      if (running) raf = requestAnimationFrame(tick);
    };

    const start = () => {
      if (running) return;
      running = true;
      raf = requestAnimationFrame(tick);
    };

    window.addEventListener(
      "scroll",
      () => {
        computeTarget();
        start();
      },
      { passive: true },
    );
    window.addEventListener("resize", () => {
      computeTarget();
      start();
    });
    // 换页后（滚动位置归零）重新对齐
    document.addEventListener("astro:page-load", () => {
      computeTarget();
      start();
    });

    const onReady = () => {
      computeTarget();
      current = target;
      painting.style.transform = `translate3d(${current}px,0,0)`;
    };
    if (painting.complete && painting.naturalWidth) onReady();
    else painting.addEventListener("load", onReady, { once: true });
  }

  document.addEventListener("astro:page-load", initLandscape);
</script>
