---
// 底部水墨山水长卷（《富春山居图》局部）。直接跟随（已被 Lenis 平滑过的）
// 滚动位置做横向平移——与页面内容共用同一条缓动曲线，阻尼一致、运动同步。跨页保留。
---

<div class="scroll-painting-container" aria-hidden="true" transition:persist="landscape">
  <img class="scroll-painting" id="scroll-painting" src="/fuchun.jpg" alt="" />
</div>

<script>
  function initLandscape() {
    if ((window as any).__landscapeBound) return;
    (window as any).__landscapeBound = true;
    const painting = document.getElementById("scroll-painting") as HTMLImageElement | null;
    if (!painting) return;

    let maxX = 0;
    const measure = () => {
      maxX = Math.max(0, painting.scrollWidth - window.innerWidth);
    };
    const apply = () => {
      const h = document.documentElement.scrollHeight - window.innerHeight;
      const p = h > 0 ? Math.min(1, Math.max(0, window.scrollY / h)) : 0;
      // 直接按（平滑后的）滚动进度定位，阻尼来自全局平滑滚动，二者同步
      painting.style.transform = `translate3d(${-p * maxX}px,0,0)`;
    };

    window.addEventListener("scroll", apply, { passive: true });
    window.addEventListener("resize", () => {
      measure();
      apply();
    });
    document.addEventListener("astro:page-load", () => {
      measure();
      apply();
    });

    const onReady = () => {
      measure();
      apply();
    };
    if (painting.complete && painting.naturalWidth) onReady();
    else painting.addEventListener("load", onReady, { once: true });
  }

  document.addEventListener("astro:page-load", initLandscape);
</script>
