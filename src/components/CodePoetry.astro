---
// 背景代码诗：随页面滚动进度逐字打出（scrubbing 打字机）。
---

<div class="code-poetry-bg gs-type" style="top:15vh;right:8vw" data-text="import { Void } from 'universe';"></div>
<div class="code-poetry-bg gs-type" style="top:25vh;left:10vw" data-text="const canvas = new Mind();\ncanvas.clear();"></div>
<div class="code-poetry-bg gs-type" style="bottom:20vh;left:5vw" data-text="while(true) {\n  seek(Dao);\n}"></div>
<div class="code-poetry-bg gs-type" style="bottom:25vh;right:12vw" data-text="// 大象无形\n/* 落笔生花 */"></div>

<script>
  let scrollHandler: (() => void) | null = null;

  function initCodePoetry() {
    const blocks = Array.from(document.querySelectorAll<HTMLElement>(".gs-type"));
    if (!blocks.length) return;

    const total = blocks.length;
    const poetry = blocks.map((block, index) => {
      const text = (block.dataset.text || "").replace(/\\n/g, "\n");
      const segment = 1 / total;
      const start = Math.max(0, index * segment - 0.1);
      const end = Math.min(1, start + 0.35);
      block.textContent = "";
      return { block, text, start, end };
    });

    let ticking = false;
    scrollHandler = () => {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(() => {
        const scrollY = window.scrollY;
        const scrollHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = scrollHeight > 0 ? scrollY / scrollHeight : 0;
        poetry.forEach((d) => {
          let local = (progress - d.start) / (d.end - d.start);
          local = Math.max(0, Math.min(1, local));
          const charCount = Math.floor(local * d.text.length);
          d.block.textContent = d.text.substring(0, charCount);
        });
        ticking = false;
      });
    };
    window.addEventListener("scroll", scrollHandler);
    scrollHandler();
  }

  function cleanup() {
    if (scrollHandler) {
      window.removeEventListener("scroll", scrollHandler);
      scrollHandler = null;
    }
  }

  document.addEventListener("astro:page-load", initCodePoetry);
  document.addEventListener("astro:before-swap", cleanup);
</script>
