---
import { getPublishedPosts, getFeedItems, PAGE_SIZE, totalPages } from "../../../lib/blog";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import FeedList from "../../../components/FeedList.astro";
import TagBar from "../../../components/TagBar.astro";
import Pager from "../../../components/Pager.astro";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const total = totalPages(getFeedItems(posts).length);
  const paths = [];
  // 第 1 页由 /blog 承担，这里只生成第 2 页起
  for (let p = 2; p <= total; p++) {
    paths.push({ params: { page: String(p) }, props: { page: p } });
  }
  return paths;
}

const { page } = Astro.props as { page: number };
const posts = await getPublishedPosts();
const feed = getFeedItems(posts);
const total = totalPages(feed.length);
const pageItems = feed.slice((page - 1) * PAGE_SIZE, page * PAGE_SIZE);
---

<BaseLayout title={`墨痕 · 第 ${page} 页`} description="文章与笔记">
  <section id="blog">
    <h2 class="gs-title">墨痕 / 文章</h2>
    <TagBar posts={posts} />
    <FeedList items={pageItems} />
    <Pager current={page} total={total} />
  </section>
</BaseLayout>
