---
import { getPublishedPosts } from "../../../lib/blog";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PostCard from "../../../components/PostCard.astro";
import TagBar from "../../../components/TagBar.astro";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const tagSet = new Set<string>();
  posts.forEach((p) => p.data.tags.forEach((t) => tagSet.add(t)));
  return [...tagSet].map((tag) => ({
    params: { tag },
    props: { tag, tagged: posts.filter((p) => p.data.tags.includes(tag)) },
  }));
}

const { tag, tagged } = Astro.props as { tag: string; tagged: Awaited<ReturnType<typeof getPublishedPosts>> };
const allPosts = await getPublishedPosts();
---

<BaseLayout title={`墨痕 · #${tag}`} description={`标签「${tag}」下的文章`}>
  <section id="blog">
    <h2 class="gs-title">墨痕 / #{tag}</h2>
    <TagBar posts={allPosts} active={tag} />
    <div class="gs-stagger">
      {tagged.map((p) => (
        <PostCard
          href={`/blog/${p.id}`}
          title={p.data.title}
          date={p.data.date}
          description={p.data.description}
          tags={p.data.tags}
        />
      ))}
    </div>
  </section>
</BaseLayout>
